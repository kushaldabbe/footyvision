# ============================================================
# FootyVision .gitignore
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
*.whl

# --- Virtual Environment ---
.venv/
venv/
env/
ENV/

# --- Data (large files, reproducible via download) ---
data/datasets/
data/sample_videos/

# --- Model weights (large binary files) ---
models/trained/
*.pt
*.onnx
*.engine
*.trt

# --- Outputs (generated artifacts) ---
outputs/

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb_metadata

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo

# --- OS ---
Thumbs.db
.DS_Store
desktop.ini

# --- Logs ---
*.log
runs/
wandb/

# --- Misc ---
*.bak
*.tmp
documentation